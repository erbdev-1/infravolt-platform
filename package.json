{
  "name": "infravolt-platform",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm validate:env && next build",
    "start": "pnpm validate:env && next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "validate:env": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --conditions=react-server --experimental-strip-types scripts/validate-production-environment.ts",
    "verify:common-contracts": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --conditions=react-server --experimental-strip-types scripts/verify-common-contracts.ts",
    "verify:env": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --conditions=react-server --experimental-strip-types scripts/verify-environment-contract.ts",
    "verify:market": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --conditions=react-server --experimental-strip-types scripts/verify-market-context.ts",
    "verify:server-boundary": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types scripts/verify-server-boundary.ts"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.13.0",
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3"
  }
}
