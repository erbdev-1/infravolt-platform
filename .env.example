# Public configuration — required in production
# Safe local origins only; replace through environment management outside Git.
NEXT_PUBLIC_SITE_URL_UK=http://uk.infravolt.localhost:3000
NEXT_PUBLIC_SITE_URL_UA=http://ua.infravolt.localhost:3000

# Public configuration — optional until the corresponding surface/provider exists
NEXT_PUBLIC_PROTECTED_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only secrets — optional until the corresponding provider exists; never commit values
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
TURNSTILE_SECRET_KEY=
CRON_SECRET=

# Server-only email configuration — optional until Resend integration
EMAIL_FROM_UK=
EMAIL_REPLY_TO_UK=
EMAIL_FROM_UA=
EMAIL_REPLY_TO_UA=

# Server-only operational configuration — optional; accepted values: debug, info, warn, error
LOG_LEVEL=
